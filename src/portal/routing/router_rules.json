{
  "version": "2.0",
  "default_model": "dolphin-llama3:8b",
  "warm_model": "dolphin-llama3:8b",
  "workspaces": {
    "_comment_personas": "Auto-generated workspace entries from prompts.chat import. Edit persona YAMLs in config/personas/ to change behavior.",
    "auto": {
      "model": "dolphin-llama3:8b",
      "lock": false,
      "fallback": ["dolphin-llama3:8b"]
    },
    "cybersecurityspecialist": {
      "model": "xploiter/the-xploiter",
      "description": "Cyber Security Specialist - specialized AI assistant for security tasks",
      "persona": "cybersecurityspecialist"
    },
    "networkengineer": {
      "model": "xploiter/the-xploiter",
      "description": "Network Engineer - specialized AI assistant for security tasks",
      "persona": "networkengineer"
    },
    "linuxterminal": {
      "model": "qwen3-coder-next:30b-q5",
      "description": "Linux Terminal - specialized AI assistant for systems tasks",
      "persona": "linuxterminal"
    },
    "pythoninterpreter": {
      "model": "qwen3-coder-next:30b-q5",
      "description": "Python Interpreter - specialized AI assistant for development tasks",
      "persona": "pythoninterpreter"
    },
    "sqlterminal": {
      "model": "qwen3-coder-next:30b-q5",
      "description": "SQL Terminal - specialized AI assistant for systems tasks",
      "persona": "sqlterminal"
    },
    "codereviewer": {
      "model": "qwen3-coder-next:30b-q5",
      "description": "Code Reviewer - specialized AI assistant for development tasks",
      "persona": "codereviewer"
    },
    "devopsengineer": {
      "model": "qwen3-coder-next:30b-q5",
      "description": "Devops Engineer - specialized AI assistant for development tasks",
      "persona": "devopsengineer"
    },
    "githubexpert": {
      "model": "qwen3-coder-next:30b-q5",
      "description": "GitHub Expert - specialized AI assistant for development tasks",
      "persona": "githubexpert"
    },
    "datascientist": {
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "description": "Data Scientist - specialized AI assistant for data tasks",
      "persona": "datascientist"
    },
    "machinelearningengineer": {
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "description": "Machine Learning Engineer - specialized AI assistant for data tasks",
      "persona": "machinelearningengineer"
    },
    "dataanalyst": {
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "description": "Data Analyst - specialized AI assistant for data tasks",
      "persona": "dataanalyst"
    },
    "statistician": {
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "description": "Statistician - specialized AI assistant for data tasks",
      "persona": "statistician"
    },
    "itarchitect": {
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "description": "IT Architect - specialized AI assistant for architecture tasks",
      "persona": "itarchitect"
    },
    "itexpert": {
      "model": "dolphin-llama3:8b",
      "description": "IT Expert - specialized AI assistant for general tasks",
      "persona": "itexpert"
    },
    "techwriter": {
      "model": "dolphin-llama3:8b",
      "description": "Tech Writer - specialized AI assistant for writing tasks",
      "persona": "techwriter"
    },
    "auto-coding": {
      "model": "qwen3-coder-next:30b-q5",
      "lock": true,
      "fallback": ["devstral:24b", "dolphin-llama3:8b"]
    },
    "auto-reasoning": {
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "lock": true,
      "fallback": ["dolphin-llama3:70b", "dolphin-llama3:8b"]
    },
    "auto-security": {
      "model": "xploiter/the-xploiter",
      "lock": true,
      "fallback": ["lazarevtill/Llama-3-WhiteRabbitNeo-8B-v2.0:q4_0", "huihui_ai/baronllm-abliterated", "dolphin-llama3:70b"]
    },
    "auto-creative": {
      "model": "dolphin-llama3:70b",
      "lock": true,
      "fallback": ["dolphin-llama3:8b"]
    },
    "auto-multimodal": {
      "model": "qwen3-omni:30b",
      "lock": true,
      "fallback": ["dolphin-llama3:8b"]
    },
    "auto-fast": {
      "model": "dolphin-llama3:8b",
      "lock": false,
      "fallback": ["dolphin-llama3:8b"]
    },
    "auto-documents": {
      "model": "qwen3-coder-next:30b-q5",
      "lock": true,
      "fallback": ["dolphin-llama3:70b", "dolphin-llama3:8b"]
    },
    "auto-video": {
      "model": "dolphin-llama3:8b",
      "lock": false,
      "fallback": ["dolphin-llama3:8b"]
    },
    "auto-music": {
      "model": "dolphin-llama3:8b",
      "lock": false,
      "fallback": ["dolphin-llama3:8b"]
    },
    "auto-research": {
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "lock": true,
      "fallback": ["dolphin-llama3:70b", "dolphin-llama3:8b"]
    }
  },
  "classifier": {
    "model": "dolphin-llama3:8b",
    "categories": {
      "general": "dolphin-llama3:8b",
      "code": "qwen3-coder-next:30b-q5",
      "reasoning": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "creative": "dolphin-llama3:70b",
      "tool_use": "dolphin-llama3:8b",
      "security": "xploiter/the-xploiter",
      "image_gen": "dolphin-llama3:8b",
      "audio_gen": "dolphin-llama3:8b",
      "video_gen": "dolphin-llama3:8b",
      "music_gen": "dolphin-llama3:8b",
      "document_gen": "qwen3-coder-next:30b-q5",
      "research": "huihui_ai/tongyi-deepresearch-abliterated:30b"
    }
  },
  "regex_rules": [
    {
      "name": "offensive_security",
      "keywords": ["(?i)\\b(exploit|shellcode|bypass|payload|reverse.?shell|pentest|red.?team|priv.?esc|kerberoast|mimikatz|bloodhound|meterpreter)\\b"],
      "model": "xploiter/the-xploiter",
      "priority": 10
    },
    {
      "name": "defensive_security",
      "keywords": ["(?i)\\b(blue.?team|siem|detection|ioc|threat.?hunt|yara|sigma|splunk|es notable|tstats|cim\\b)"],
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "priority": 10
    },
    {
      "name": "coding",
      "keywords": ["(?i)\\b(write|debug|function|class|def |import |async def|refactor)\\b"],
      "model": "qwen3-coder-next:30b-q5",
      "priority": 8
    },
    {
      "name": "reasoning",
      "keywords": ["(?i)\\b(analyze|reason|think through|explain why|step by step)\\b"],
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "priority": 7
    },
    {
      "name": "document_gen",
      "keywords": ["(?i)\\b(write.?doc|create.?presentation|make.?spreadsheet|generate.?report|create.?word|make.?powerpoint|create.?excel)\\b"],
      "model": "qwen3-coder-next:30b-q5",
      "priority": 8
    },
    {
      "name": "video_gen",
      "keywords": ["(?i)\\b(create.?video|generate.?video|make.?video|animate|video.?clip|video.?generation|render.?video)\\b"],
      "model": "dolphin-llama3:8b",
      "priority": 9
    },
    {
      "name": "music_gen",
      "keywords": ["(?i)\\b(compose.?music|create.?music|generate.?song|generate.?music|make.?soundtrack|create.?beat|music.?generation)\\b"],
      "model": "dolphin-llama3:8b",
      "priority": 9
    },
    {
      "name": "research",
      "keywords": ["(?i)\\b(deep.?research|deep.?dive|investigate|find.?information.?about|comprehensive.?analysis)\\b"],
      "model": "huihui_ai/tongyi-deepresearch-abliterated:30b",
      "priority": 7
    }
  ],
  "manual_override_prefix": "@model:",
  "auth_token_env": "ROUTER_TOKEN"
}
